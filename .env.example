# 在线自习室 — 环境变量配置
# 复制此文件为 backend/.env 并填写实际值

# JWT 密钥（生产环境请使用强随机字符串）
JWT_SECRET=studyroom-dev-secret

# QQ 邮箱 SMTP 配置
# 1. 登录 QQ 邮箱 → 设置 → 账户 → 开启 POP3/SMTP 服务 → 获取授权码
# 2. 将授权码填到下面 SMTP_PASSWORD
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USER=your_qq_email@qq.com
SMTP_PASSWORD=your_smtp_authorization_code

# 日志（可选，bedrock 框架自动读取）
# LOG_LEVEL=INFO
# LOG_FILE=logs/app.log
# LOG_ROTATION=500 MB
# LOG_RETENTION=7 days
# LOG_COMPRESSION=zip
