# 在线自习室 — 环境变量配置
# 复制此文件为 backend/.env 并填写实际值

# JWT 密钥（HS256 签名，必填，要求 ≥32 字符）
# 生成强随机值：python3 -c "import secrets; print(secrets.token_urlsafe(64))"
# ⚠️ 不要使用此示例值；每个部署应有独立密钥
JWT_SECRET=replace_with_secrets_token_urlsafe_64_output

# QQ 邮箱 SMTP 配置
# 1. 登录 QQ 邮箱 → 设置 → 账户 → 开启 POP3/SMTP 服务 → 获取授权码
# 2. 将授权码填到下面 SMTP_PASSWORD
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USER=your_qq_email@qq.com
SMTP_PASSWORD=your_smtp_authorization_code

# 日志（可选，bedrock 框架自动读取）
# LOG_LEVEL=INFO
# LOG_FILE=logs/app.log
# LOG_ROTATION=500 MB
# LOG_RETENTION=7 days
# LOG_COMPRESSION=zip
