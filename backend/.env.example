# QQ 邮箱 SMTP 配置
# 1. 登录 QQ 邮箱 → 设置 → 账户 → 开启 POP3/SMTP 服务 → 获取授权码
# 2. 将授权码填到下面 SMTP_PASSWORD
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USER=your_email@qq.com
SMTP_PASSWORD=your_smtp_authorization_code

# JWT 密钥（HS256 签名，512 bits 熵 / secrets.token_urlsafe(64) 生成）
# ⚠️ 切勿提交此值到代码仓库；轮换时所有已签发 token 立即失效
JWT_SECRET=generate_a_new_secret_with_python_secrets_token_urlsafe_64

# 数据库配置（MySQL）
DATABASE_TYPE=mysql
DATABASE_DRIVER=pymysql
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_USERNAME=studyroom
DATABASE_PASSWORD=your_mysql_password
DATABASE_SCHEMA=studyroom
